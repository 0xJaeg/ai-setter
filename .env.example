# Copy this to .env.local and fill in real values.
# Set META_APP_SECRET=stub to run in test mode without real Meta credentials
# (Graph API calls are logged instead of sent).

# --- Meta / Instagram ---
# From: developers.facebook.com -> your app -> Settings -> Basic
META_APP_ID=
META_APP_SECRET=

# Long-lived Page Access Token (generate via Graph API Explorer, then exchange for long-lived)
META_PAGE_ACCESS_TOKEN=

# Your IG Business User ID (GET /me/accounts -> instagram_business_account.id)
META_IG_USER_ID=

# A string YOU invent. Meta sends it back in the webhook subscription handshake.
# Set the same value in: App Dashboard -> Webhooks -> Verify Token
META_WEBHOOK_VERIFY_TOKEN=

# --- LLM ---
# https://platform.deepseek.com -> API Keys
DEEPSEEK_API_KEY=

# --- Supabase ---
# https://supabase.com/dashboard -> your project -> Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
